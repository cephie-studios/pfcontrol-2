---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchApi } from '../../lib/api';
import ProfileContent from '@app/islands/ProfileContent';

interface Role {
  id: number;
  name: string;
  description: string | null;
  color: string;
  icon: string;
  priority: number;
}

interface FeaturedFlight {
  id: string;
  callsign?: string;
  departure?: string;
  arrival?: string;
  aircraft?: string;
  status?: string;
  snap_images: Array<{ cephie_id: string; url: string }>;
  created_at?: string;
}

interface PilotProfile {
  user: {
    id: string;
    username: string;
    discriminator: string;
    avatar: string | null;
    roblox_username: string | null;
    vatsim_cid: string | null;
    vatsim_rating_short: string | null;
    vatsim_rating_long: string | null;
    member_since: string;
    is_admin: boolean;
    roles: Role[];
    bio: string;
    statistics: Record<string, unknown>;
    rating: { averageRating: number; ratingCount: number } | null;
    background_image?: {
      selectedImage?: string;
      useCustomBackground?: boolean;
    } | null;
  };
  privacySettings: {
    displayControllerStatsOnProfile: boolean;
    displayPilotStatsOnProfile: boolean;
    displayControllerRatingOnProfile: boolean;
    displayLinkedAccountsOnProfile: boolean;
    displayBackgroundOnProfile: boolean;
  };
  featuredFlights?: FeaturedFlight[];
}

const { username } = Astro.params;

if (!username) {
  return Astro.redirect('/');
}

const profile = await fetchApi<PilotProfile>(
  `/api/pilot/${encodeURIComponent(username)}`
);

if (!profile) {
  return new Response(null, { status: 404 });
}

const { user, privacySettings, featuredFlights } = profile;

type Statistics = Record<string, unknown>;

function getStat(stats: Statistics, key: string): number | null {
  const val = stats?.[key];
  if (typeof val === 'number') return val;
  if (typeof val === 'object' && val !== null) {
    const nested = (val as Record<string, unknown>)['total'];
    if (typeof nested === 'number') return nested;
  }
  return null;
}

function formatTimeControlling(rawMins: number | null): string {
  if (rawMins === null) return '—';
  const mins = Math.floor(rawMins);
  if (mins >= 60) {
    const h = Math.floor(mins / 60);
    const rem = mins % 60;
    return rem === 0 ? `${h}h` : `${h}h ${rem}min`;
  }
  return `${mins} min`;
}

function getDiscordAvatar(
  userId: string,
  avatarHash: string | null,
  size = 256
): string {
  if (!avatarHash) return '/assets/app/default/avatar.webp';
  return `https://cdn.discordapp.com/avatars/${userId}/${avatarHash}.png?size=${size}`;
}

function formatMemberSince(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  } catch {
    return dateStr;
  }
}

const avatarUrl = getDiscordAvatar(user.id, user.avatar);
const memberSince = formatMemberSince(user.member_since);
const profileUrl = `https://pfcontrol.com/user/${user.username}`;

function toPlainText(s: string): string {
  return s
    .replace(/<[^>]*>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

const plainBio = user.bio ? toPlainText(user.bio) : '';
const rolesText =
  user.roles?.length > 0
    ? user.roles
        .map((r) => r.name)
        .filter(Boolean)
        .join(', ')
    : '';

const sessionsN = privacySettings.displayPilotStatsOnProfile
  ? getStat(user.statistics, 'total_sessions_created')
  : null;
const flightsN = privacySettings.displayPilotStatsOnProfile
  ? getStat(user.statistics, 'total_flights_submitted')
  : null;
const ctrlMins = privacySettings.displayPilotStatsOnProfile
  ? getStat(user.statistics, 'total_time_controlling_minutes')
  : null;

const statsBits: string[] = [];
if (sessionsN != null)
  statsBits.push(`${sessionsN.toLocaleString('en-US')} sessions created`);
if (flightsN != null)
  statsBits.push(`${flightsN.toLocaleString('en-US')} flights submitted`);
if (ctrlMins != null)
  statsBits.push(`${formatTimeControlling(ctrlMins)} controlling`);

const statsSentence =
  statsBits.length > 0 ? `Stats: ${statsBits.join('; ')}.` : '';

function truncateMeta(s: string, max: number): string {
  if (s.length <= max) return s;
  return `${s.slice(0, max - 1).trimEnd()}…`;
}

const pageTitle = `${user.username} on PFControl — pilot & ATC profile`;

const descParts: string[] = [
  `${user.username} on PFControl — public pilot and air traffic control profile.`,
];
if (plainBio) descParts.push(plainBio);
if (rolesText) descParts.push(`Roles: ${rolesText}.`);
descParts.push(`Member since ${memberSince}.`);
if (user.is_admin) descParts.push('PFControl platform team.');
if (privacySettings.displayLinkedAccountsOnProfile) {
  if (user.roblox_username) descParts.push(`Roblox: ${user.roblox_username}.`);
  if (user.vatsim_cid)
    descParts.push(
      `VATSIM CID ${user.vatsim_cid}${user.vatsim_rating_short ? ` (${user.vatsim_rating_short})` : ''}.`
    );
}
if (statsSentence) descParts.push(statsSentence);
if (
  privacySettings.displayControllerRatingOnProfile &&
  user.rating &&
  user.rating.ratingCount > 0
) {
  descParts.push(
    `Controller rating ${user.rating.averageRating.toFixed(1)}/5 from ${user.rating.ratingCount} ${user.rating.ratingCount === 1 ? 'rating' : 'ratings'}.`
  );
}
descParts.push(
  `Find ${user.username} on PFControl at pfcontrol.com/user/${user.username}.`
);

const pageDescription = truncateMeta(descParts.join(' '), 320);

const keywordParts = [
  'PFControl',
  user.username,
  'PFControl profile',
  `${user.username} PFControl`,
  'flight strips',
  'ATC',
  'VATSIM',
  'pilot profile',
  'air traffic control',
];
if (rolesText) keywordParts.push(...user.roles.map((r) => r.name));
if (user.roblox_username && privacySettings.displayLinkedAccountsOnProfile) {
  keywordParts.push('Roblox', user.roblox_username);
}
if (user.vatsim_cid && privacySettings.displayLinkedAccountsOnProfile) {
  keywordParts.push('VATSIM', `VATSIM ${user.vatsim_cid}`);
}
const keywords = [...new Set(keywordParts)].join(', ');

const sameAs: string[] = [profileUrl];
if (privacySettings.displayLinkedAccountsOnProfile && user.roblox_username) {
  sameAs.push(
    `https://www.roblox.com/search/users?keyword=${encodeURIComponent(user.roblox_username)}`
  );
}
if (privacySettings.displayLinkedAccountsOnProfile && user.vatsim_cid) {
  sameAs.push(`https://stats.vatsim.net/stats/${user.vatsim_cid}`);
}

const knowsAbout: string[] = [...(user.roles?.map((r) => r.name) ?? [])];
if (user.vatsim_rating_long) knowsAbout.push(user.vatsim_rating_long);

const personDescription =
  plainBio ||
  `${user.username} is a member of the PFControl flight strip and ATC community. Member since ${memberSince}.`;

const personNode: Record<string, unknown> = {
  '@type': 'Person',
  '@id': `${profileUrl}#person`,
  name: user.username,
  alternateName: [`@${user.username}`, `${user.username} on PFControl`],
  url: profileUrl,
  image: {
    '@type': 'ImageObject',
    url: avatarUrl,
    caption: `${user.username} — PFControl profile photo`,
  },
  description: truncateMeta(personDescription, 4000),
  identifier: `https://pfcontrol.com/user/${user.username}`,
  mainEntityOfPage: { '@id': `${profileUrl}#webpage` },
  memberOf: {
    '@type': 'Organization',
    '@id': 'https://pfcontrol.com/#organization',
    name: 'PFControl',
    url: 'https://pfcontrol.com',
    description:
      'Real-time flight strip platform for air traffic control simulation.',
  },
  ...(knowsAbout.length > 0 && { knowsAbout }),
  ...(sameAs.length > 1 && { sameAs: [...new Set(sameAs)] }),
  ...(user.is_admin && {
    jobTitle: 'PFControl administrator',
  }),
  ...(!user.is_admin && {
    jobTitle: 'PFControl pilot & ATC community member',
  }),
};

if (
  privacySettings.displayControllerRatingOnProfile &&
  user.rating &&
  user.rating.ratingCount > 0
) {
  personNode.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: user.rating.averageRating,
    ratingCount: user.rating.ratingCount,
    bestRating: 5,
    worstRating: 1,
  };
}

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://pfcontrol.com/#website',
      name: 'PFControl',
      url: 'https://pfcontrol.com',
      publisher: { '@id': 'https://pfcontrol.com/#organization' },
    },
    {
      '@type': 'Organization',
      '@id': 'https://pfcontrol.com/#organization',
      name: 'PFControl',
      url: 'https://pfcontrol.com',
      logo: {
        '@type': 'ImageObject',
        url: 'https://pfcontrol.com/favicon.svg',
      },
    },
    {
      '@type': 'WebPage',
      '@id': `${profileUrl}#webpage`,
      url: profileUrl,
      name: pageTitle,
      description: pageDescription,
      isPartOf: { '@id': 'https://pfcontrol.com/#website' },
      about: { '@id': `${profileUrl}#person` },
      primaryImageOfPage: { '@type': 'ImageObject', url: avatarUrl },
      inLanguage: 'en',
      ...(rolesText && { keywords: rolesText }),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'PFControl',
          item: 'https://pfcontrol.com',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: user.username,
          item: profileUrl,
        },
      ],
    },
    personNode,
    ...(featuredFlights?.length
      ? [
          {
            '@type': 'ItemList',
            name: `Featured flights — ${user.username} on PFControl`,
            description: `Flight strips and highlights on ${user.username}'s public PFControl pilot profile.`,
            numberOfItems: featuredFlights.length,
            itemListElement: featuredFlights.map((f, i) => ({
              '@type': 'ListItem',
              position: i + 1,
              name: f.callsign ?? `Flight ${String(f.id).slice(0, 8)}`,
              url: `https://pfcontrol.com/flight/${f.id}`,
              ...(f.departure &&
                f.arrival && {
                  description: `${f.departure} → ${f.arrival}${f.aircraft ? ` · ${f.aircraft}` : ''}`,
                }),
            })),
          },
        ]
      : []),
  ],
};

const pilotStats = privacySettings.displayPilotStatsOnProfile
  ? ([
      {
        label: 'Sessions Created',
        value: getStat(user.statistics, 'total_sessions_created'),
      },
      {
        label: 'Flights Submitted',
        value: getStat(user.statistics, 'total_flights_submitted'),
      },
      { label: 'Time Controlling', value: null as number | null },
    ] as Array<{ label: string; value: number | null }>)
  : [];

if (privacySettings.displayPilotStatsOnProfile) {
  const rawMins = getStat(user.statistics, 'total_time_controlling_minutes');
  if (rawMins !== null) {
    const mins = Math.floor(rawMins);
    const h = Math.floor(mins / 60);
    const rem = mins % 60;
    pilotStats[2].value = rawMins;
  }
}
---

<BaseLayout
  showFooter={false}
  title={pageTitle}
  description={pageDescription}
  ogType="profile"
  ogImage={avatarUrl}
  ogProfileUsername={user.username}
  canonicalUrl={profileUrl}
  structuredData={structuredData}
  keywords={keywords}
>
  <ProfileContent username={user.username} client:only="react" />
</BaseLayout>
