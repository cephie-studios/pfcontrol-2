{
  "name": "pfcontrol-2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "set NODE_ENV=development && npm run generate:developer-docs && concurrently \"vp dev\" \"npx nodemon\"",
    "dev:astro": "cd astro && npx astro dev --port 4321",
    "prod": "cross-env NODE_ENV=production node server/dist/main.js",
    "generate:developer-docs": "tsx scripts/generate-developer-api-docs.ts",
    "prepare": "node scripts/install-hooks.mjs",
    "precommit": "npm audit --audit-level=high",
    "build": "npm run build:server && npm run build:astro && npm run generate:developer-docs && vp build --mode production",
    "build:server": "tsc --project server/tsconfig.json",
    "build:astro": "cd astro && npm install && npx astro build",
    "build:dev": "npm run generate:developer-docs && vp build --mode development",
    "build-only": "vp build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "postinstall": "node scripts/verify-node-modules.mjs"
  },
